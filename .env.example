# Toggle to "1" to use the official eBay Browse API instead of HTML scraping.
EBAY_USE_API=0

# Get these by registering at https://developer.ebay.com (free).
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=

# Override sandbox/production endpoint if needed (leave blank for production).
EBAY_API_BASE=

# Optional: override the default user-agent for HTTP requests.
USER_AGENT=
